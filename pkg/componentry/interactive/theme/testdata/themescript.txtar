-- init script --
<script>(()=>{var e=localStorage.getItem("themePreference")||"system";document.documentElement.setAttribute("data-theme-preference",e),(e==="dark"||e==="system"&&window.matchMedia("(prefers-color-scheme: dark)").matches)&&document.documentElement.classList.add("dark")})();</script>
-- theme script --
<script>(()=>{var r=document.querySelector("[data-theme-selector]");r?.addEventListener("click",()=>{var t=["light","dark","system"],a=localStorage.getItem("themePreference")||"system",e=t[(t.indexOf(a)+1)%t.length];localStorage.setItem("themePreference",e),document.documentElement.setAttribute("data-theme-preference",e),e==="dark"||e==="system"&&window.matchMedia("(prefers-color-scheme: dark)").matches?document.documentElement.classList.add("dark"):document.documentElement.classList.remove("dark")})})();</script>
-- theme selector default --
<button data-theme-selector="" type="button" aria-label="Toggle theme"><span class="theme-light-icon">Light</span><span class="theme-dark-icon">Dark</span><span class="theme-system-icon">System</span></button>
-- theme selector custom icons --
<button data-theme-selector="" type="button" aria-label="Toggle theme"><span class="theme-light-icon">sun</span><span class="theme-dark-icon">moon</span><span class="theme-system-icon">monitor</span></button>
-- theme selector extra nodes --
<button data-theme-selector="" type="button" aria-label="Toggle theme"><span class="theme-light-icon">Light</span><span class="theme-dark-icon">Dark</span><span class="theme-system-icon">System</span>extra-content</button>
