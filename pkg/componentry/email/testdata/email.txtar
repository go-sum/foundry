-- layout with title --
<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>My Email</title></head><body bgcolor="#f4f4f4" style="background-color:#f4f4f4;margin:0;padding:0;"><table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#f4f4f4;"><tbody><tr><td align="center" style="padding:40px 16px;"><table width="600" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#ffffff;border-radius:4px;max-width:600px;width:100%;"><tbody><tr><td style="padding:40px;font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;"><p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;margin:0 0 16px 0;">body</p></td></tr></tbody></table></td></tr></tbody></table></body></html>
-- layout zero value --
<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title></title></head><body bgcolor="#f4f4f4" style="background-color:#f4f4f4;margin:0;padding:0;"><table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#f4f4f4;"><tbody><tr><td align="center" style="padding:40px 16px;"><table width="600" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#ffffff;border-radius:4px;max-width:600px;width:100%;"><tbody><tr><td style="padding:40px;font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;"><p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;margin:0 0 16px 0;">content</p></td></tr></tbody></table></td></tr></tbody></table></body></html>
-- layout custom bg color --
<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title></title></head><body bgcolor="#123456" style="background-color:#123456;margin:0;padding:0;"><table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#123456;"><tbody><tr><td align="center" style="padding:40px 16px;"><table width="600" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#ffffff;border-radius:4px;max-width:600px;width:100%;"><tbody><tr><td style="padding:40px;font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;"><p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;margin:0 0 16px 0;">x</p></td></tr></tbody></table></td></tr></tbody></table></body></html>
-- layout custom content width --
<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title></title></head><body bgcolor="#f4f4f4" style="background-color:#f4f4f4;margin:0;padding:0;"><table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#f4f4f4;"><tbody><tr><td align="center" style="padding:40px 16px;"><table width="480" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#ffffff;border-radius:4px;max-width:480px;width:100%;"><tbody><tr><td style="padding:40px;font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;"><p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;margin:0 0 16px 0;">x</p></td></tr></tbody></table></td></tr></tbody></table></body></html>
-- layout with footer --
<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title></title></head><body bgcolor="#f4f4f4" style="background-color:#f4f4f4;margin:0;padding:0;"><table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#f4f4f4;"><tbody><tr><td align="center" style="padding:40px 16px;"><table width="600" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#ffffff;border-radius:4px;max-width:600px;width:100%;"><tbody><tr><td style="padding:40px;font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;"><p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;margin:0 0 16px 0;">body</p></td></tr><tr><td align="center" style="padding:16px;"><p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;margin:0 0 16px 0;">Footer line</p></td></tr></tbody></table></td></tr></tbody></table></body></html>
-- h1 --
<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:28px;font-weight:bold;color:#111827;margin:0 0 16px 0;">Big Heading</h1>
-- h2 --
<h2 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:bold;color:#111827;margin:0 0 12px 0;">Section</h2>
-- p --
<p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#374151;margin:0 0 16px 0;">A paragraph.</p>
-- button --
<table cellpadding="0" cellspacing="0" role="presentation"><tbody><tr><td style="background-color:#111827;border-radius:6px;text-align:center;"><a href="https://example.com" style="color:#ffffff;text-decoration:none;font-weight:600;padding:12px 24px;display:inline-block;font-family:Arial,Helvetica,sans-serif;font-size:16px;">Click me</a></td></tr></tbody></table>
-- a --
<a href="https://example.com" style="color:#2563EB;text-decoration:underline;">Click here</a>
-- hr --
<table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tbody><tr><td style="border-top:1px solid #E5E7EB;padding:16px 0;"></td></tr></tbody></table>
-- preview text --
<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">Check this out&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;</div>
