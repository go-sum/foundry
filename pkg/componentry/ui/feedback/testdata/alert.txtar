-- default variant --
<div class="relative w-full rounded-lg border px-4 py-3 text-sm grid gap-1.5 items-start backdrop-blur-sm border-primary/30 bg-primary/20 text-primary [&amp;_[data-alert-description]]:text-muted-foreground" role="alert" aria-live="polite"><h5 class="line-clamp-1 min-h-4 font-medium tracking-tight">Heads up</h5><div class="grid justify-items-start gap-1 text-sm" data-alert-description="">This is an informational alert.</div></div>
-- destructive variant --
<div class="relative w-full rounded-lg border px-4 py-3 text-sm grid gap-1.5 items-start backdrop-blur-sm border-destructive/30 bg-destructive/20 text-destructive [&amp;_[data-alert-description]]:text-destructive/80" role="alert" aria-live="assertive"><h5 class="line-clamp-1 min-h-4 font-medium tracking-tight">Error</h5><div class="grid justify-items-start gap-1 text-sm" data-alert-description="">Something went wrong.</div></div>
-- default dismissible --
<div class="relative w-full rounded-lg border px-4 py-3 text-sm grid gap-1.5 items-start backdrop-blur-sm border-primary/30 bg-primary/20 text-primary [&amp;_[data-alert-description]]:text-muted-foreground" role="alert" aria-live="polite" data-dismissible=""><div class="grid justify-items-start gap-1 text-sm" data-alert-description="">Dismissible message.</div><button data-dismiss="alert" class="absolute top-3 right-3 opacity-70 hover:opacity-100 transition-opacity outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50" type="button" aria-label="Dismiss">×</button></div>
-- destructive dismissible --
<div class="relative w-full rounded-lg border px-4 py-3 text-sm grid gap-1.5 items-start backdrop-blur-sm border-destructive/30 bg-destructive/20 text-destructive [&amp;_[data-alert-description]]:text-destructive/80" role="alert" aria-live="assertive" data-dismissible=""><div class="grid justify-items-start gap-1 text-sm" data-alert-description="">Dismissible error.</div><button data-dismiss="alert" class="absolute top-3 right-3 opacity-70 hover:opacity-100 transition-opacity outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50" type="button" aria-label="Dismiss">×</button></div>
-- with icon --
<div class="relative w-full rounded-lg border px-4 py-3 text-sm grid grid-cols-[auto_1fr] gap-x-3 items-start backdrop-blur-sm border-primary/30 bg-primary/20 text-primary [&amp;_[data-alert-description]]:text-muted-foreground" role="alert" aria-live="polite"><div data-alert-icon="" class="mt-0.5">ℹ</div><div class="grid gap-1.5"><h5 class="line-clamp-1 min-h-4 font-medium tracking-tight">Info</h5><div class="grid justify-items-start gap-1 text-sm" data-alert-description="">Alert with icon column.</div></div></div>
-- destructive with icon --
<div class="relative w-full rounded-lg border px-4 py-3 text-sm grid grid-cols-[auto_1fr] gap-x-3 items-start backdrop-blur-sm border-destructive/30 bg-destructive/20 text-destructive [&amp;_[data-alert-description]]:text-destructive/80" role="alert" aria-live="assertive"><div data-alert-icon="" class="mt-0.5">✕</div><div class="grid gap-1.5"><h5 class="line-clamp-1 min-h-4 font-medium tracking-tight">Error</h5><div class="grid justify-items-start gap-1 text-sm" data-alert-description="">Destructive with icon.</div></div></div>
-- with id --
<div class="relative w-full rounded-lg border px-4 py-3 text-sm grid gap-1.5 items-start backdrop-blur-sm border-primary/30 bg-primary/20 text-primary [&amp;_[data-alert-description]]:text-muted-foreground" role="alert" aria-live="polite" id="my-alert"><div class="grid justify-items-start gap-1 text-sm" data-alert-description="">Identified alert.</div></div>
-- zero value --
<div class="relative w-full rounded-lg border px-4 py-3 text-sm grid gap-1.5 items-start backdrop-blur-sm border-primary/30 bg-primary/20 text-primary [&amp;_[data-alert-description]]:text-muted-foreground" role="alert" aria-live="polite"></div>
