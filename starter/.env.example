# ───────────────────────────────────────────────────── environment variables───
# APP_ENV controls environment-specific config overlays.
# Valid values: production (default), development, testing
APP_ENV=

# ────────────────────────────────────────────────────────────────── secrets ───
# Secrets should be stored in a secrets store like docker secrets or similar

# Generate with: openssl rand -hex 32
SECURITY_CSRF_KEY=

# During rotation, place the retiring key here (comma-separated, most-recent-first).
# Keep for at least one TokenTTL (default 1h) after rolling to the new key.
SECURITY_CSRF_KEY_PREVIOUS=
