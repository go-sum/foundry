-- default variant --
<span class="inline-flex items-center justify-center rounded-md border px-2 py-0.5 text-xs font-medium w-fit whitespace-nowrap shrink-0 transition-colors border-transparent bg-primary text-primary-foreground">New</span>
-- secondary variant --
<span class="inline-flex items-center justify-center rounded-md border px-2 py-0.5 text-xs font-medium w-fit whitespace-nowrap shrink-0 transition-colors border-transparent bg-secondary text-secondary-foreground">Draft</span>
-- destructive variant --
<span class="inline-flex items-center justify-center rounded-md border px-2 py-0.5 text-xs font-medium w-fit whitespace-nowrap shrink-0 transition-colors border-transparent bg-destructive text-white">Error</span>
-- outline variant --
<span class="inline-flex items-center justify-center rounded-md border px-2 py-0.5 text-xs font-medium w-fit whitespace-nowrap shrink-0 transition-colors text-foreground">Beta</span>
-- with id --
<span class="inline-flex items-center justify-center rounded-md border px-2 py-0.5 text-xs font-medium w-fit whitespace-nowrap shrink-0 transition-colors border-transparent bg-primary text-primary-foreground" id="my-badge">Tagged</span>
-- with icon child --
<span class="inline-flex items-center justify-center rounded-md border px-2 py-0.5 text-xs font-medium w-fit whitespace-nowrap shrink-0 transition-colors border-transparent bg-primary text-primary-foreground">★ Featured</span>
