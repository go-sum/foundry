<a class="inline-flex items-center justify-center size-9 rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 hover:bg-accent hover:text-accent-foreground" href="/page/3"></a>
-- previous enabled --
<a class="inline-flex items-center gap-1 px-2.5 h-9 rounded-md text-sm font-medium outline-none transition-colors focus-visible:ring-[3px] focus-visible:ring-ring/50 hover:bg-accent hover:text-accent-foreground" href="/page/1" aria-label="Go to previous page"><svg class="size-4" aria-hidden="true"><use href="#"></use></svg><span>Previous</span></a>
