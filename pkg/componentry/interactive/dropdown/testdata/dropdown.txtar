-- root empty props --
<details data-popover="" class="relative inline-block"></details>
-- root with id --
<details data-popover="" class="relative inline-block" id="user-menu"></details>
-- trigger with children --
<summary class="list-none cursor-pointer outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground">Options<svg class="size-4 shrink-0 text-muted-foreground" aria-hidden="true"><use href="#"></use></svg></summary>
-- trigger no children --
<summary class="list-none cursor-pointer outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground"><svg class="size-4 shrink-0 text-muted-foreground" aria-hidden="true"><use href="#"></use></svg></summary>
-- item link --
<a class="flex w-full items-center rounded-sm px-2 py-1.5 text-sm outline-none transition-colors focus-visible:bg-accent focus-visible:text-accent-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 cursor-default hover:bg-accent hover:text-accent-foreground" href="/settings">Settings</a>
-- item button --
<button class="flex w-full items-center rounded-sm px-2 py-1.5 text-sm outline-none transition-colors focus-visible:bg-accent focus-visible:text-accent-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 cursor-default hover:bg-accent hover:text-accent-foreground" type="button">Delete</button>
-- item disabled link --
<a class="flex w-full items-center rounded-sm px-2 py-1.5 text-sm outline-none transition-colors focus-visible:bg-accent focus-visible:text-accent-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 opacity-50" aria-disabled="true" tabindex="-1">Archive</a>
-- item disabled button --
<button class="flex w-full items-center rounded-sm px-2 py-1.5 text-sm outline-none transition-colors focus-visible:bg-accent focus-visible:text-accent-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 opacity-50" type="button" disabled>Save</button>
-- separator --
<div class="-mx-1 my-1 h-px bg-muted" role="separator"></div>
-- label --
<div class="px-2 py-1.5 text-sm font-semibold">My Account</div>
