# ───────────────────────────────────────────────────── environment variables ───
# APP_ENV controls environment-specific config overlays.
# Valid values: production (default), development, testing
APP_ENV=

# ──────────────────────────────────────────────────────────── database (pg) ───
PGHOST=db
PGPORT=5432
PGDATABASE=foundry
PGUSER=
PGPASSWORD=

# DATABASE_URL is derived from the above in production, or set directly.
# Stored as a Docker secret — set via task secrets:init
# DATABASE_URL=postgres://user:pass@db:5432/foundry?sslmode=disable

# ─────────────────────────────────────────────────────────────── cache (kv) ───
KV_HOST=kv
KV_PORT=6379
KV_PASSWORD=

# ────────────────────────────────────────────────────────────────── secrets ───
# Secrets are stored as Docker secret files in .secrets/ — generated by task secrets:init.
# These values in .env are used ONLY to bootstrap the secret files.

# Generate with: openssl rand -hex 32
SECURITY_CSRF_KEY=

# During rotation, place the retiring key here (comma-separated, most-recent-first).
SECURITY_CSRF_KEY_PREVIOUS=

# Separate secret for auth verification token encryption (AEAD key).
# Must be distinct from SECURITY_CSRF_KEY to maintain cryptographic key separation.
# Generate with: openssl rand -hex 32
SECURITY_AUTH_TOKEN_KEY=

# ──────────────────────────────────────────────────────────────── production ───
# Domain used by Caddy in production (e.g. example.com).
# Required by: task prod
PROD_DOMAIN=

# ───────────────────────────────────────────────────── site / OAuth config ───
# Required for production. Defaults to http://forge.test in development.
# SITE_BASE_URL=https://example.com

# OAuth issuer URL. Defaults to SITE_BASE_URL. Set explicitly if issuer differs.
# AUTH_ISSUER=https://example.com

# First-party OAuth client ID. Default: starter-app
# AUTH_FIRST_PARTY_CLIENT_ID=starter-app
