# ───────────────────────────────────────────────────── environment variables ───
# APP_ENV controls environment-specific config overlays.
# Valid values: production (default), development, testing
APP_ENV=

# ──────────────────────────────────────────────────────────── database (pg) ───
# Single source of truth for the database connection.
# PGUSER and PGPASSWORD are extracted automatically for the Postgres container.
# Stored as a Docker secret — generated by task secrets:init
DATABASE_URL=postgres://user:password@db:5432/foundry?sslmode=disable

# ─────────────────────────────────────────────────────────────── cache (kv) ───
KV_HOST=kv
KV_PORT=6379
KV_PASSWORD=

# ────────────────────────────────────────────────────────────────── secrets ───
# Secrets are stored as Docker secret files in .secrets/ — generated by task secrets:init.
# These values in .env are used ONLY to bootstrap the secret files.

# Generate with: openssl rand -hex 32
SECURITY_CSRF_KEY=

# Separate secret for auth verification token encryption (AEAD key).
# Must be distinct from SECURITY_CSRF_KEY to maintain cryptographic key separation.
# Generate with: openssl rand -hex 32
SECURITY_AUTH_TOKEN_KEY=

# ──────────────────────────────────────────────────────────── reverse proxy ───
# CIDR ranges of trusted reverse proxies whose X-Forwarded-Proto is accepted.
# Set to the exact CIDR(s) of your ingress proxy — not broad RFC 1918 space.
# Without this, the app ignores X-Forwarded-Proto and resolves all proxied
# requests as http://, causing incorrect scheme in redirects and forwarded headers.
# task prod auto-detects the local Docker proxy subnet when this is unset.
# Override it explicitly for non-local ingress proxies.
SERVER_TRUSTED_PROXIES=

# ──────────────────────────────────────────────────────────────── production ───
# Optional Caddy host override for production (e.g. example.com).
# Defaults to the hostname from SITE_BASE_URL when unset.
PROD_DOMAIN=

# ───────────────────────────────────────────────────── site / OAuth config ───
# Required for production. In development, defaults to https://foundry.test when
# unset. If your project name differs (DEV_DOMAIN = <project>.test), set this
# to match your actual dev domain — it controls AllowedHosts enforcement.
# SITE_BASE_URL=https://example.com

# Additional hostnames the server accepts beyond the SITE_BASE_URL hostname.
# Comma-separated. Useful for aliases, subdomains, or CDN hostnames.
# SITE_ALLOWED_HOSTS=www.example.com,cdn.example.com

# OAuth issuer URL. Defaults to SITE_BASE_URL. Set explicitly if issuer differs.
# AUTH_ISSUER=https://example.com

# First-party OAuth client ID. Default: starter-app
# AUTH_FIRST_PARTY_CLIENT_ID=starter-app
