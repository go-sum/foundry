-- basic field --
<div class="grid gap-2"><label class="text-sm font-medium leading-none inline-block" for="email">Email</label>&lt;input&gt;</div>
-- with description --
<div class="grid gap-2"><label class="text-sm font-medium leading-none inline-block" for="email">Email</label>&lt;input&gt;<p class="text-sm text-muted-foreground" id="email-description">We&#39;ll never share your email.</p></div>
-- with hint --
<div class="grid gap-2"><label class="text-sm font-medium leading-none inline-block" for="password">Password</label>&lt;input&gt;<p class="text-xs text-muted-foreground" id="password-hint">At least 8 characters.</p></div>
-- with errors --
<div class="grid gap-2"><label class="text-sm font-medium leading-none inline-block text-destructive" for="email">Email</label>&lt;input&gt;<div class="grid gap-1" id="email-error"><p class="text-xs text-destructive">Email is required</p><p class="text-xs text-destructive">Must be a valid email</p></div></div>
-- with all assistive text --
<div class="grid gap-2"><label class="text-sm font-medium leading-none inline-block text-destructive" for="email">Email</label>&lt;input&gt;<p class="text-sm text-muted-foreground" id="email-description">Your primary email.</p><p class="text-xs text-muted-foreground" id="email-hint">Use your work email.</p><div class="grid gap-1" id="email-error"><p class="text-xs text-destructive">Invalid format</p></div></div>
-- required field --
<div class="grid gap-2"><label class="text-sm font-medium leading-none inline-block" for="name">Name<span class="ml-0.5 text-destructive" aria-hidden="true">*</span></label>&lt;input&gt;</div>
-- zero value --
<div class="grid gap-2"></div>
